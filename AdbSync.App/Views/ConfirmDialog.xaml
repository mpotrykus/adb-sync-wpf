<Window x:Class="AdbSync.App.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:interop="clr-namespace:AdbSync.App.Interop"
        xmlns:controls="clr-namespace:AdbSync.App.Controls"
        interop:AcrylicEffect.Enabled="True"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Icon="/Assets/app.ico" SizeToContent="Height" Width="460" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="0" GlassFrameThickness="0" CornerRadius="8" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Border Style="{StaticResource WindowRootBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <controls:TitleBar Grid.Row="0" ShowMinMax="False"/>

            <StackPanel Grid.Row="1" Margin="20">
                <Border Style="{StaticResource CardBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="IconText" Grid.Column="0" Text="&#xE7BA;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="22"
                                   Foreground="{StaticResource Brush.Warning}" VerticalAlignment="Top" Margin="0,2,14,0"/>
                        <TextBlock x:Name="MessageText" Grid.Column="1" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton" Content="Cancel" Width="90" Margin="0,0,8,0" Click="Cancel_Click" IsCancel="True"/>
                    <Button x:Name="SecondaryButton" Width="150" Margin="0,0,8,0" Click="Secondary_Click" Visibility="Collapsed"/>
                    <Button x:Name="ConfirmButton" Width="110" Style="{StaticResource DangerButton}" Click="Confirm_Click" IsDefault="True"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
