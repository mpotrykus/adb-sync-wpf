<Window x:Class="AdbSync.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:interop="clr-namespace:AdbSync.App.Interop"
        xmlns:controls="clr-namespace:AdbSync.App.Controls"
        interop:AcrylicEffect.Enabled="True" interop:WindowHeightLimit.Enabled="True"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Title="Settings" Icon="/Assets/app.ico" SizeToContent="Height" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="0" GlassFrameThickness="0" CornerRadius="8" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Border Style="{StaticResource WindowRootBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <controls:TitleBar Grid.Row="0" ShowMinMax="False"/>

            <ScrollViewer Grid.Row="1" Margin="20,20,20,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Projects Directory" Style="{StaticResource SectionLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ProjectsDirectoryBox" Grid.Column="0" Margin="0,0,8,0"
                                         controls:TextBoxHelper.Placeholder="C:\Users\you\Documents\AdbSync Projects"/>
                                <Button Grid.Column="1" Content="Browse..." Click="Browse_Click"/>
                            </Grid>
                            <TextBlock x:Name="ProjectsDirectoryErrorText" Style="{StaticResource ValidationErrorText}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Notifications" Style="{StaticResource SectionLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <CheckBox x:Name="StartAtLoginBox" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
                                <TextBlock Text="Start AdbSync when I log in" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <CheckBox x:Name="ShowInfoNotificationsBox" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
                                <TextBlock Text="Show notifications for successful syncs" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="ShowErrorNotificationsBox" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
                                <TextBlock Text="Show notifications for sync errors" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Quiet Hours" Style="{StaticResource SectionLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <CheckBox x:Name="QuietHoursEnabledBox" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
                                <TextBlock Text="Suppress notifications during quiet hours" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="From" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" x:Name="QuietHoursStartBox" controls:TextBoxHelper.Placeholder="22:00"/>
                                <TextBlock Grid.Column="3" Text="To" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="4" x:Name="QuietHoursEndBox" controls:TextBoxHelper.Placeholder="07:00"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Scheduling" Style="{StaticResource SectionLabel}"/>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="RunMissedSchedulesBox" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
                                <TextBlock Text="Run scheduled jobs that were missed while AdbSync was closed" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}">
                        <Expander Header="Advanced" IsExpanded="False">
                            <StackPanel>
                                <Border Style="{StaticResource NestedSection}">
                                    <StackPanel>
                                        <TextBlock Text="LOCKING &amp; CONCURRENCY" Style="{StaticResource SubSectionLabel}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                                                <Run Text="Stale lock timeout "/><Run Text="(hours)" Style="{StaticResource DescriptorRun}"/>
                                            </TextBlock>
                                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="StaleLockHoursBox" controls:TextBoxHelper.Placeholder="4"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Max concurrent jobs" VerticalAlignment="Center" Margin="0,12,0,0"/>
                                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="MaxConcurrentJobsBox" Margin="0,12,0,0" controls:TextBoxHelper.Placeholder="1"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource NestedSection}">
                                    <StackPanel>
                                        <TextBlock Text="RETENTION" Style="{StaticResource SubSectionLabel}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                                                <Run Text="Log retention "/><Run Text="(days)" Style="{StaticResource DescriptorRun}"/>
                                            </TextBlock>
                                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="LogRetentionDaysBox" controls:TextBoxHelper.Placeholder="30"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,12,0,0">
                                                <Run Text="Max log file size "/><Run Text="(mb)" Style="{StaticResource DescriptorRun}"/>
                                            </TextBlock>
                                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="PerLogFileMaxMegabytesBox" Margin="0,12,0,0" controls:TextBoxHelper.Placeholder="5"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,12,0,0">
                                                <Run Text="Conflict backup retention "/><Run Text="(days)" Style="{StaticResource DescriptorRun}"/>
                                            </TextBlock>
                                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="ConflictRetentionDaysBox" Margin="0,12,0,0" controls:TextBoxHelper.Placeholder="30"/>
                                            <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,12,0,0">
                                                <Run Text="Checkpoint retention "/><Run Text="(days)" Style="{StaticResource DescriptorRun}"/>
                                            </TextBlock>
                                            <TextBox Grid.Row="3" Grid.Column="1" x:Name="CheckpointRetentionDaysBox" Margin="0,12,0,0" controls:TextBoxHelper.Placeholder="30"/>
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Run history entries kept per job" VerticalAlignment="Center" Margin="0,12,0,0"/>
                                            <TextBox Grid.Row="4" Grid.Column="1" x:Name="MaxRunHistoryEntriesBox" Margin="0,12,0,0" controls:TextBoxHelper.Placeholder="50"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource NestedSection}">
                                    <StackPanel>
                                        <TextBlock Text="TRANSFER" Style="{StaticResource SubSectionLabel}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                                                <Run Text="Bandwidth throttle "/><Run Text="(kb/s, blank = unlimited)" Style="{StaticResource DescriptorRun}"/>
                                            </TextBlock>
                                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="BandwidthThrottleKBpsBox" controls:TextBoxHelper.Placeholder="Unlimited"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Transfer retry attempts" VerticalAlignment="Center" Margin="0,12,0,0"/>
                                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="RetryMaxAttemptsBox" Margin="0,12,0,0" controls:TextBoxHelper.Placeholder="3"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,12,0,0">
                                                <Run Text="Retry backoff "/><Run Text="(seconds)" Style="{StaticResource DescriptorRun}"/>
                                            </TextBlock>
                                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="RetryBackoffSecondsBox" Margin="0,12,0,0" controls:TextBoxHelper.Placeholder="5"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource NestedSection}" Margin="0">
                                    <StackPanel>
                                        <TextBlock Text="SAFETY &amp; CONFLICTS" Style="{StaticResource SubSectionLabel}"/>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" VerticalAlignment="Center">
                                                <Run Text="Push safety minimum "/><Run Text="(% of baseline)" Style="{StaticResource DescriptorRun}"/>
                                            </TextBlock>
                                            <TextBox Grid.Column="1" x:Name="PushSafetyMinimumPercentBox" controls:TextBoxHelper.Placeholder="25"/>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox x:Name="BackupConflictLosersBox" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Back up conflict losers before overwriting" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Expander>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="20,12,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Set to Default" Width="110" Click="SetToDefault_Click"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="Cancel_Click" IsCancel="True"/>
                    <Button Content="Save" Width="90" Style="{StaticResource PrimaryButton}" Click="Save_Click" IsDefault="True"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
