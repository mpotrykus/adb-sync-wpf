<Window x:Class="AdbSync.App.Views.RestoreCheckpointWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:interop="clr-namespace:AdbSync.App.Interop"
        xmlns:controls="clr-namespace:AdbSync.App.Controls"
        interop:AcrylicEffect.Enabled="True" interop:WindowHeightLimit.Enabled="True"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Icon="/Assets/app.ico" Height="480" Width="640" MinHeight="320" MinWidth="480" WindowStartupLocation="CenterOwner">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="8" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Border Style="{StaticResource WindowRootBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <controls:TitleBar Grid.Row="0"/>

            <DockPanel Grid.Row="1" Margin="20">
                <TextBlock DockPanel.Dock="Top" Text="Pick a checkpoint to restore. Restoring pushes it back out to every matching device, overwriting current device files and deleting anything not in the checkpoint."
                           TextWrapping="Wrap" Margin="0,0,0,12" Foreground="{StaticResource Brush.Text.Secondary}"/>

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="Cancel_Click" IsCancel="True"/>
                    <Button x:Name="RestoreButton" Content="Restore" Width="110" Style="{StaticResource DangerButton}" Click="Restore_Click" IsEnabled="False"/>
                </StackPanel>

                <DataGrid x:Name="SnapshotsGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                          HeadersVisibility="Column" GridLinesVisibility="None" SelectionMode="Single"
                          SelectionChanged="SnapshotsGrid_SelectionChanged" MouseDoubleClick="SnapshotsGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="CREATED" Binding="{Binding CreatedText}" Width="170"/>
                        <DataGridTextColumn Header="DEVICES" Binding="{Binding DevicesText}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    <Setter Property="ToolTip" Value="{Binding DevicesText}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="" Width="75">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource RowButton}" Click="OpenFolder_Click" ToolTip="Open folder">
                                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>
    </Border>
</Window>
