<Window x:Class="AdbSync.App.Views.PackageBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:interop="clr-namespace:AdbSync.App.Interop"
        xmlns:controls="clr-namespace:AdbSync.App.Controls"
        interop:AcrylicEffect.Enabled="True" interop:WindowHeightLimit.Enabled="True"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Title="Choose App Package" Icon="/Assets/app.ico" Height="560" Width="480" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="0" GlassFrameThickness="0" CornerRadius="8" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Border Style="{StaticResource WindowRootBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <controls:TitleBar Grid.Row="0" ShowMinMax="False"/>

            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Search" Style="{StaticResource SectionLabel}"/>
                        <TextBox x:Name="SearchBox" controls:TextBoxHelper.Placeholder="Filter packages..." TextChanged="SearchBox_TextChanged"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1" Margin="0,12,0,0">
                    <ListBox x:Name="PackagesList" MouseDoubleClick="PackagesList_MouseDoubleClick"/>
                    <TextBlock x:Name="EmptyText" Text="No packages found." Style="{StaticResource CaptionText}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0" Visibility="Collapsed"/>
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                    <Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="Cancel_Click" IsCancel="True"/>
                    <Button Content="Select" Width="120" Style="{StaticResource PrimaryButton}" Click="Select_Click" IsDefault="True"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
