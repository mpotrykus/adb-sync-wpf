<Window x:Class="AdbSync.App.Views.JobEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:interop="clr-namespace:AdbSync.App.Interop"
        xmlns:controls="clr-namespace:AdbSync.App.Controls"
        xmlns:conv="clr-namespace:AdbSync.App.Converters"
        interop:AcrylicEffect.Enabled="True" interop:WindowHeightLimit.Enabled="True"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Title="Job" Icon="/Assets/app.ico" Width="960" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="0" GlassFrameThickness="0" CornerRadius="8" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter"/>
        <conv:NullableBoolToOverrideStateConverter x:Key="NullableBoolToOverrideStateConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>
    <Border Style="{StaticResource WindowRootBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <controls:TitleBar Grid.Row="0" ShowMinMax="False" ShowClose="False"/>

            <ScrollViewer Grid.Row="1" Margin="20,20,20,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource CardBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" x:Name="EnabledCheckBox" Style="{StaticResource ToggleSwitch}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Enabled" FontWeight="SemiBold"/>
                                <TextBlock Text="When off, this job never runs, regardless of its schedule." Style="{StaticResource CaptionText}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Name" Style="{StaticResource SectionLabel}"/>
                                <TextBox x:Name="NameBox" Margin="0,0,0,4" controls:TextBoxHelper.Placeholder="e.g. Photos Backup"/>
                                <TextBlock x:Name="NameErrorText" Style="{StaticResource ValidationErrorText}"/>

                                <TextBlock Text="App package" Style="{StaticResource SectionLabel}"/>
                                <TextBlock Style="{StaticResource CaptionText}" Text="Optional. The job is skipped while this app is running on any device."/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" x:Name="AppPackageBox" Margin="0,0,8,0" controls:TextBoxHelper.Placeholder="com.example.app"/>
                                    <Button Grid.Column="1" x:Name="BrowseAppPackageButton" Content="Browse..." IsEnabled="False" Click="BrowseAppPackage_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Devices" Style="{StaticResource SectionLabel}"/>

                                <ItemsControl x:Name="DeviceBindingsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0AFFFFFF" CornerRadius="6" Padding="10,7" Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap">
                                                        <Run Text="{Binding DeviceName, Mode=OneWay}" FontWeight="SemiBold"/>
                                                        <Run Text=" &#8594; "/>
                                                        <Run Text="{Binding RemotePath, Mode=OneWay}" Foreground="{StaticResource Brush.Text.Secondary}"/>
                                                    </TextBlock>
                                                    <Button Grid.Column="1" Style="{StaticResource RowDangerButton}" Margin="8,0,0,0"
                                                            Tag="{Binding}" Click="RemoveBinding_Click" ToolTip="Remove">
                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock x:Name="NoDevicesText" Text="No devices added yet." Style="{StaticResource CaptionText}" Margin="0,0,0,10"/>
                                <TextBlock x:Name="DevicesErrorText" Style="{StaticResource ValidationErrorText}"/>

                                <Border Height="1" Background="{StaticResource Brush.Divider}" Margin="0,0,0,14"/>

                                <TextBlock Text="ADD A DEVICE" Foreground="{StaticResource Brush.Text.Secondary}"
                                           FontWeight="SemiBold" FontSize="11" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="DevicePicker" Grid.Column="0" Margin="0,0,8,0"/>
                                    <TextBox x:Name="RemotePathBox" Grid.Column="1" Margin="0,0,8,0" controls:TextBoxHelper.Placeholder="/sdcard/DCIM"/>
                                    <Button Grid.Column="2" Content="Browse..." Click="BrowseRemotePath_Click"/>
                                </Grid>
                                <Button Content="Add Device" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch" Margin="0,0,0,16" Click="AddBinding_Click"/>

                                <Border Height="1" Background="{StaticResource Brush.Divider}" Margin="0,0,0,14"/>

                                <Button x:Name="TestWatchButton" Content="Test Watch Availability" HorizontalAlignment="Left" Click="TestWatch_Click"/>
                                <ItemsControl x:Name="TestResultsList" Margin="0,10,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0AFFFFFF" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Style="{StaticResource StatusDot}" Fill="{Binding StatusBrush}" VerticalAlignment="Top" Margin="0,5,8,0"/>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Header}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Detail}" Foreground="{StaticResource Brush.Text.Secondary}" FontSize="12" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Exclude patterns" Style="{StaticResource SectionLabel}"/>
                                <TextBlock Text="One glob pattern per line." Style="{StaticResource CaptionText}"/>
                                <TextBox x:Name="ExcludeBox" AcceptsReturn="True" Height="200" FontFamily="Cascadia Mono, Consolas"
                                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" AcceptsTab="True"
                                         controls:TextBoxHelper.Placeholder="*.tmp&#10;*/.thumbnails/*"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Schedule" Style="{StaticResource SectionLabel}"/>

                                <RadioButton x:Name="ScheduleManual" Content="Manual" GroupName="Schedule" Margin="0,4,0,14"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                    <RadioButton x:Name="ScheduleInterval" Content="Every" GroupName="Schedule" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBox x:Name="IntervalValueBox" Width="50" Margin="0,0,6,0" controls:TextBoxHelper.Placeholder="4"
                                             IsEnabled="{Binding IsChecked, ElementName=ScheduleInterval}"/>
                                    <ComboBox x:Name="IntervalUnitCombo" Width="90"
                                              IsEnabled="{Binding IsChecked, ElementName=ScheduleInterval}">
                                        <ComboBoxItem Content="Seconds"/>
                                        <ComboBoxItem Content="Minutes"/>
                                        <ComboBoxItem Content="Hours"/>
                                        <ComboBoxItem Content="Days"/>
                                        <ComboBoxItem Content="Weeks"/>
                                        <ComboBoxItem Content="Months"/>
                                        <ComboBoxItem Content="Years"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                    <RadioButton x:Name="ScheduleDailyAt" Content="Daily at" GroupName="Schedule" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBox x:Name="DailyTimesBox" Width="180" controls:TextBoxHelper.Placeholder="06:00, 18:30"
                                             IsEnabled="{Binding IsChecked, ElementName=ScheduleDailyAt}"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <RadioButton x:Name="ScheduleOnChange" Content="On device change" GroupName="Schedule" VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,12"
                                            Visibility="{Binding IsChecked, ElementName=ScheduleOnChange, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal" Margin="26,8,0,16">
                                        <TextBlock Text="Debounce" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource Brush.Text.Secondary}"
                                                   ToolTip="Quiet period after the last detected change before the job actually runs, so a burst of writes triggers one sync instead of many."/>
                                        <TextBox x:Name="DebounceSecondsBox" Width="50" Margin="0,0,6,0" controls:TextBoxHelper.Placeholder="10"
                                                 IsEnabled="{Binding IsChecked, ElementName=ScheduleOnChange}"
                                                 ToolTip="Quiet period after the last detected change before the job actually runs, so a burst of writes triggers one sync instead of many."/>
                                        <TextBlock Text="sec" VerticalAlignment="Center" Foreground="{StaticResource Brush.Text.Secondary}"/>

                                        <TextBlock Text="|" Margin="12,0" VerticalAlignment="Center" Foreground="{StaticResource Brush.Text.Secondary}"/>

                                        <TextBlock Text="Rescan folders every" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource Brush.Text.Secondary}"
                                                   ToolTip="Changes are detected instantly via a live watch. This interval only controls how often that watch re-checks for newly created subfolders, since it isn't recursive by default."/>
                                        <TextBox x:Name="RescanIntervalMinutesBox" Width="50" Margin="0,0,6,0" controls:TextBoxHelper.Placeholder="15"
                                                 IsEnabled="{Binding IsChecked, ElementName=ScheduleOnChange}"
                                                 ToolTip="Changes are detected instantly via a live watch. This interval only controls how often that watch re-checks for newly created subfolders, since it isn't recursive by default."/>
                                        <TextBlock Text="min" VerticalAlignment="Center" Foreground="{StaticResource Brush.Text.Secondary}"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="* Use 'Test Watch Availability' to confirm that this device and path support live-watching."
                                           Style="{StaticResource CaptionText}" Margin="26,0,0,0" TextWrapping="Wrap"
                                           Visibility="{Binding IsChecked, ElementName=ScheduleOnChange, Converter={StaticResource BoolToVisibility}}"/>
                                <TextBlock Text="Changes are detected instantly; the rescan interval only refreshes which subfolders are being watched."
                                           Style="{StaticResource CaptionText}" Margin="26,12,0,12" TextWrapping="Wrap"
                                           Visibility="{Binding IsChecked, ElementName=ScheduleOnChange, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>
                        </Border>
                        </StackPanel>
                    </Grid>

                    <Border Style="{StaticResource CardBorder}">
                        <Expander Header="Advanced (overrides)" IsExpanded="False">
                            <StackPanel>
                                <TextBlock Text="Blank fields inherit the global default from Settings. A filled field shows an accent bar to mark it as an explicit override."
                                           Style="{StaticResource CaptionText}" Margin="0,0,0,12"/>

                                <Border Style="{StaticResource NestedSection}">
                                    <StackPanel>
                                        <TextBlock Text="LOCATION" Style="{StaticResource SubSectionLabel}"/>
                                        <TextBlock Text="Project directory override" Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid Grid.Column="0" Margin="0,0,8,0">
                                                <TextBox x:Name="ProjectDirectoryBox" controls:TextBoxHelper.Placeholder="Default: Settings > Projects directory"/>
                                                <Rectangle Style="{StaticResource OverrideIndicatorBar}"
                                                           Visibility="{Binding Text, ElementName=ProjectDirectoryBox, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                                            </Grid>
                                            <Button Grid.Column="1" Content="Browse..." Click="BrowseProjectDirectory_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource NestedSection}">
                                    <StackPanel>
                                        <TextBlock Text="LOCKING &amp; RETENTION" Style="{StaticResource SubSectionLabel}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                                                <Run Text="Stale lock timeout "/><Run Text="(hours)" Style="{StaticResource DescriptorRun}"/>
                                            </TextBlock>
                                            <Grid Grid.Row="0" Grid.Column="1">
                                                <TextBox x:Name="StaleLockHoursOverrideBox" controls:TextBoxHelper.Placeholder="Inherit"/>
                                                <Rectangle Style="{StaticResource OverrideIndicatorBar}"
                                                           Visibility="{Binding Text, ElementName=StaleLockHoursOverrideBox, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                                            </Grid>
                                            <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center">
                                                <Run Text="Conflict backup retention "/><Run Text="(days)" Style="{StaticResource DescriptorRun}"/>
                                            </TextBlock>
                                            <Grid Grid.Row="0" Grid.Column="4">
                                                <TextBox x:Name="ConflictRetentionDaysOverrideBox" controls:TextBoxHelper.Placeholder="Inherit"/>
                                                <Rectangle Style="{StaticResource OverrideIndicatorBar}"
                                                           Visibility="{Binding Text, ElementName=ConflictRetentionDaysOverrideBox, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                                            </Grid>

                                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,12,0,0">
                                                <Run Text="Checkpoint retention "/><Run Text="(days)" Style="{StaticResource DescriptorRun}"/>
                                            </TextBlock>
                                            <Grid Grid.Row="1" Grid.Column="1" Margin="0,12,0,0">
                                                <TextBox x:Name="CheckpointRetentionDaysOverrideBox" controls:TextBoxHelper.Placeholder="Inherit"/>
                                                <Rectangle Style="{StaticResource OverrideIndicatorBar}"
                                                           Visibility="{Binding Text, ElementName=CheckpointRetentionDaysOverrideBox, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                                            </Grid>
                                            <TextBlock Grid.Row="1" Grid.Column="3" Text="Run history entries kept" VerticalAlignment="Center" Margin="0,12,0,0"/>
                                            <Grid Grid.Row="1" Grid.Column="4" Margin="0,12,0,0">
                                                <TextBox x:Name="MaxRunHistoryEntriesOverrideBox" controls:TextBoxHelper.Placeholder="Inherit"/>
                                                <Rectangle Style="{StaticResource OverrideIndicatorBar}"
                                                           Visibility="{Binding Text, ElementName=MaxRunHistoryEntriesOverrideBox, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                                            </Grid>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource NestedSection}">
                                    <StackPanel>
                                        <TextBlock Text="TRANSFER" Style="{StaticResource SubSectionLabel}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                                                <Run Text="Bandwidth throttle "/><Run Text="(kb/s)" Style="{StaticResource DescriptorRun}"/>
                                            </TextBlock>
                                            <Grid Grid.Row="0" Grid.Column="1">
                                                <TextBox x:Name="BandwidthThrottleKBpsOverrideBox" controls:TextBoxHelper.Placeholder="Inherit"/>
                                                <Rectangle Style="{StaticResource OverrideIndicatorBar}"
                                                           Visibility="{Binding Text, ElementName=BandwidthThrottleKBpsOverrideBox, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                                            </Grid>
                                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Retry attempts" VerticalAlignment="Center"/>
                                            <Grid Grid.Row="0" Grid.Column="4">
                                                <TextBox x:Name="RetryMaxAttemptsOverrideBox" controls:TextBoxHelper.Placeholder="Inherit"/>
                                                <Rectangle Style="{StaticResource OverrideIndicatorBar}"
                                                           Visibility="{Binding Text, ElementName=RetryMaxAttemptsOverrideBox, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                                            </Grid>

                                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,12,0,0">
                                                <Run Text="Retry backoff "/><Run Text="(seconds)" Style="{StaticResource DescriptorRun}"/>
                                            </TextBlock>
                                            <Grid Grid.Row="1" Grid.Column="1" Margin="0,12,0,0">
                                                <TextBox x:Name="RetryBackoffSecondsOverrideBox" controls:TextBoxHelper.Placeholder="Inherit"/>
                                                <Rectangle Style="{StaticResource OverrideIndicatorBar}"
                                                           Visibility="{Binding Text, ElementName=RetryBackoffSecondsOverrideBox, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                                            </Grid>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource NestedSection}">
                                    <StackPanel>
                                        
                                        <TextBlock Text="SAFETY &amp; NOTIFICATIONS" Style="{StaticResource SubSectionLabel}"/>
                                        
                                        <Grid Margin="0,0,0,12">
                                            
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="315"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>

                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            
                                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                                                <Run Text="Push safety minimum "/><Run Text="(%)" Style="{StaticResource DescriptorRun}"/>
                                            </TextBlock>
                                            <Grid Grid.Row="0" Grid.Column="1">
                                                <TextBox x:Name="PushSafetyMinimumPercentOverrideBox" controls:TextBoxHelper.Placeholder="Inherit"/>
                                                <Rectangle Style="{StaticResource OverrideIndicatorBar}"
                                                           Visibility="{Binding Text, ElementName=PushSafetyMinimumPercentOverrideBox, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                                            </Grid>

                                            <CheckBox Grid.Row="1" Grid.Column="0" x:Name="ShowInfoNotificationsOverrideBox" IsThreeState="True" Content="Show notifications for successful syncs" Margin="0,12,0,0"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource CaptionText}" Margin="12,12,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                       Text="{Binding IsChecked, ElementName=ShowInfoNotificationsOverrideBox, Converter={StaticResource NullableBoolToOverrideStateConverter}}"/>

                                            <CheckBox Grid.Row="2" Grid.Column="0" x:Name="ShowErrorNotificationsOverrideBox" IsThreeState="True" Content="Show notifications for sync errors" Margin="0,12,0,0"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource CaptionText}" Margin="12,12,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                       Text="{Binding IsChecked, ElementName=ShowErrorNotificationsOverrideBox, Converter={StaticResource NullableBoolToOverrideStateConverter}}"/>

                                            <CheckBox Grid.Row="3" Grid.Column="0" x:Name="BackupConflictLosersOverrideBox" IsThreeState="True" Content="Back up the losing side of a merge conflict" Margin="0,12,0,0"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource CaptionText}" Margin="12,12,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                       Text="{Binding IsChecked, ElementName=BackupConflictLosersOverrideBox, Converter={StaticResource NullableBoolToOverrideStateConverter}}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource NestedSection}" Margin="0">
                                    <StackPanel>
                                        <TextBlock Text="TESTING" Style="{StaticResource SubSectionLabel}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox x:Name="DryRunBox" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Dry run - rehearse this job without writing to master or pushing to devices" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Expander>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,12,20,20">
                <Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="Cancel_Click" IsCancel="True"/>
                <Button Content="Save" Width="90" Style="{StaticResource PrimaryButton}" Click="Save_Click" IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
