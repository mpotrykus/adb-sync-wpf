<Window x:Class="AdbSync.App.Views.JobEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:interop="clr-namespace:AdbSync.App.Interop"
        xmlns:controls="clr-namespace:AdbSync.App.Controls"
        interop:AcrylicEffect.Enabled="True"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Title="Job" Icon="/Assets/app.ico" Width="960" SizeToContent="Height" MaxHeight="900"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="0" GlassFrameThickness="0" CornerRadius="8" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Border Style="{StaticResource WindowRootBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <controls:TitleBar Grid.Row="0" ShowMinMax="False"/>

            <ScrollViewer Grid.Row="1" Margin="20" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource CardBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" x:Name="EnabledCheckBox" Style="{StaticResource ToggleSwitch}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Enabled" FontWeight="SemiBold"/>
                                <TextBlock Text="When off, this job never runs, regardless of its schedule." Style="{StaticResource CaptionText}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Name" Style="{StaticResource SectionLabel}"/>
                                <TextBox x:Name="NameBox" Margin="0,0,0,14" controls:TextBoxHelper.Placeholder="e.g. Photos Backup"/>

                                <TextBlock Text="App package" Style="{StaticResource SectionLabel}"/>
                                <TextBlock Style="{StaticResource CaptionText}" Text="Optional. The job is skipped while this app is running on any device."/>
                                <TextBox x:Name="AppPackageBox" controls:TextBoxHelper.Placeholder="com.example.app"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Devices" Style="{StaticResource SectionLabel}"/>

                                <ItemsControl x:Name="DeviceBindingsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0AFFFFFF" CornerRadius="6" Padding="10,7" Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap">
                                                        <Run Text="{Binding DeviceName, Mode=OneWay}" FontWeight="SemiBold"/>
                                                        <Run Text=" &#8594; "/>
                                                        <Run Text="{Binding RemotePath, Mode=OneWay}" Foreground="{StaticResource Brush.Text.Secondary}"/>
                                                    </TextBlock>
                                                    <Button Grid.Column="1" Style="{StaticResource RowDangerButton}" Margin="8,0,0,0"
                                                            Tag="{Binding}" Click="RemoveBinding_Click" ToolTip="Remove">
                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock x:Name="NoDevicesText" Text="No devices added yet." Style="{StaticResource CaptionText}" Margin="0,0,0,10"/>

                                <Border Height="1" Background="{StaticResource Brush.Divider}" Margin="0,0,0,14"/>

                                <TextBlock Text="ADD A DEVICE" Foreground="{StaticResource Brush.Text.Secondary}"
                                           FontWeight="SemiBold" FontSize="11" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="DevicePicker" Grid.Column="0" Margin="0,0,8,0"/>
                                    <TextBox x:Name="RemotePathBox" Grid.Column="1" Margin="0,0,8,0" controls:TextBoxHelper.Placeholder="/sdcard/DCIM"/>
                                    <Button Grid.Column="2" Content="Browse..." Click="BrowseRemotePath_Click"/>
                                </Grid>
                                <Button Content="Add Device" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch" Margin="0,0,0,16" Click="AddBinding_Click"/>

                                <Border Height="1" Background="{StaticResource Brush.Divider}" Margin="0,0,0,14"/>

                                <Button x:Name="TestWatchButton" Content="Test Watch Availability" HorizontalAlignment="Left" Click="TestWatch_Click"/>
                                <ItemsControl x:Name="TestResultsList" Margin="0,10,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0AFFFFFF" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Style="{StaticResource StatusDot}" Fill="{Binding StatusBrush}" VerticalAlignment="Top" Margin="0,5,8,0"/>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Header}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Detail}" Foreground="{StaticResource Brush.Text.Secondary}" FontSize="12" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Exclude patterns" Style="{StaticResource SectionLabel}"/>
                                <TextBlock Text="One glob pattern per line." Style="{StaticResource CaptionText}"/>
                                <TextBox x:Name="ExcludeBox" AcceptsReturn="True" Height="200" FontFamily="Cascadia Mono, Consolas"
                                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" AcceptsTab="True"
                                         controls:TextBoxHelper.Placeholder="*.tmp&#10;*/.thumbnails/*"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Schedule" Style="{StaticResource SectionLabel}"/>

                                <RadioButton x:Name="ScheduleManual" Content="Manual" GroupName="Schedule" Margin="0,4,0,14"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                    <RadioButton x:Name="ScheduleInterval" Content="Every" GroupName="Schedule" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBox x:Name="IntervalHoursBox" Width="50" Margin="0,0,6,0" controls:TextBoxHelper.Placeholder="4"
                                             IsEnabled="{Binding IsChecked, ElementName=ScheduleInterval}"/>
                                    <TextBlock Text="hours" VerticalAlignment="Center" Foreground="{StaticResource Brush.Text.Secondary}"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                    <RadioButton x:Name="ScheduleDailyAt" Content="Daily at" GroupName="Schedule" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBox x:Name="DailyTimesBox" Width="180" controls:TextBoxHelper.Placeholder="06:00, 18:30"
                                             IsEnabled="{Binding IsChecked, ElementName=ScheduleDailyAt}"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <RadioButton x:Name="ScheduleOnChange" Content="On device change" GroupName="Schedule" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="debounce" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource Brush.Text.Secondary}"/>
                                    <TextBox x:Name="DebounceSecondsBox" Width="50" Margin="0,0,6,0" controls:TextBoxHelper.Placeholder="10"
                                             IsEnabled="{Binding IsChecked, ElementName=ScheduleOnChange}"/>
                                    <TextBlock Text="sec" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource Brush.Text.Secondary}"/>
                                    <TextBlock Text="rescan every" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource Brush.Text.Secondary}"/>
                                    <TextBox x:Name="RescanIntervalMinutesBox" Width="50" Margin="0,0,6,0" controls:TextBoxHelper.Placeholder="15"
                                             IsEnabled="{Binding IsChecked, ElementName=ScheduleOnChange}"/>
                                    <TextBlock Text="min" VerticalAlignment="Center" Foreground="{StaticResource Brush.Text.Secondary}"/>
                                </StackPanel>
                                <TextBlock Text="Use Test Watch Availability to confirm this device and path support live watching."
                                           Style="{StaticResource CaptionText}" Margin="26,0,0,0"/>
                            </StackPanel>
                        </Border>
                        </StackPanel>
                    </Grid>

                    <Border Style="{StaticResource CardBorder}">
                        <Expander Header="Advanced (overrides)" IsExpanded="False">
                            <StackPanel>
                                <TextBlock Text="Blank fields inherit the global default from Settings." Style="{StaticResource CaptionText}" Margin="0,0,0,4"/>

                                <TextBlock Text="LOCATION" Style="{StaticResource SubSectionLabel}" Margin="0,12,0,8"/>
                                <TextBlock Text="Project directory override" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="ProjectDirectoryBox" Grid.Column="0" Margin="0,0,8,0" controls:TextBoxHelper.Placeholder="Default: Settings > Projects directory"/>
                                    <Button Grid.Column="1" Content="Browse..." Click="BrowseProjectDirectory_Click"/>
                                </Grid>

                                <Border Height="1" Background="{StaticResource Brush.Divider}" Margin="0,4,0,14"/>

                                <TextBlock Text="LOCKING &amp; RETENTION" Style="{StaticResource SubSectionLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Stale lock timeout (hours)" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="StaleLockHoursOverrideBox" controls:TextBoxHelper.Placeholder="inherit"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Conflict backup retention (days)" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="4" x:Name="ConflictRetentionDaysOverrideBox" controls:TextBoxHelper.Placeholder="inherit"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Checkpoint retention (days)" VerticalAlignment="Center" Margin="0,10,0,0"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="CheckpointRetentionDaysOverrideBox" Margin="0,10,0,0" controls:TextBoxHelper.Placeholder="inherit"/>
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Run history entries kept" VerticalAlignment="Center" Margin="0,10,0,0"/>
                                    <TextBox Grid.Row="1" Grid.Column="4" x:Name="MaxRunHistoryEntriesOverrideBox" Margin="0,10,0,0" controls:TextBoxHelper.Placeholder="inherit"/>
                                </Grid>

                                <Border Height="1" Background="{StaticResource Brush.Divider}" Margin="0,16,0,14"/>

                                <TextBlock Text="TRANSFER" Style="{StaticResource SubSectionLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Bandwidth throttle (KB/s)" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="BandwidthThrottleKBpsOverrideBox" controls:TextBoxHelper.Placeholder="inherit"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Retry attempts" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="0" Grid.Column="4" x:Name="RetryMaxAttemptsOverrideBox" controls:TextBoxHelper.Placeholder="inherit"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Retry backoff (seconds)" VerticalAlignment="Center" Margin="0,10,0,0"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="RetryBackoffSecondsOverrideBox" Margin="0,10,0,0" controls:TextBoxHelper.Placeholder="inherit"/>
                                </Grid>

                                <Border Height="1" Background="{StaticResource Brush.Divider}" Margin="0,16,0,14"/>

                                <TextBlock Text="SAFETY &amp; NOTIFICATIONS" Style="{StaticResource SubSectionLabel}"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Push safety minimum (%)" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" x:Name="PushSafetyMinimumPercentOverrideBox" controls:TextBoxHelper.Placeholder="inherit"/>
                                </Grid>
                                <CheckBox x:Name="ShowInfoNotificationsOverrideBox" IsThreeState="True" Content="Show notifications for successful syncs (unset = inherit)" Margin="0,0,0,10"/>
                                <CheckBox x:Name="ShowErrorNotificationsOverrideBox" IsThreeState="True" Content="Show notifications for sync errors (unset = inherit)" Margin="0,0,0,10"/>
                                <CheckBox x:Name="BackupConflictLosersOverrideBox" IsThreeState="True" Content="Back up the losing side of a merge conflict (unset = inherit)"/>

                                <Border Height="1" Background="{StaticResource Brush.Divider}" Margin="0,14,0,14"/>

                                <TextBlock Text="TESTING" Style="{StaticResource SubSectionLabel}"/>
                                <CheckBox x:Name="DryRunBox" Content="Dry run - rehearse this job without writing to master or pushing to devices"/>
                            </StackPanel>
                        </Expander>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                        <Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="Cancel_Click" IsCancel="True"/>
                        <Button Content="Save" Width="90" Style="{StaticResource PrimaryButton}" Click="Save_Click" IsDefault="True"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
