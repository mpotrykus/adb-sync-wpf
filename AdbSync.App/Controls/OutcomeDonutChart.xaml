<UserControl x:Class="AdbSync.App.Controls.OutcomeDonutChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             SizeChanged="OnSizeChanged">
    <Grid>
        <Canvas x:Name="RingCanvas"/>
        <StackPanel x:Name="CenterPanel" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
            <TextBlock x:Name="CenterValueText" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock x:Name="CenterLabelText" FontSize="10" HorizontalAlignment="Center"
                       Foreground="{StaticResource Brush.Text.Secondary}"/>
        </StackPanel>
        <TextBlock x:Name="EmptyText" Text="Not enough runs yet" Style="{StaticResource EmptyStateText}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
    </Grid>
</UserControl>
